# Family Dashboard MCP server — environment.
# Copy to .env and fill in your values.

# URL of the dashboard server (the Raspberry Pi) as seen from the machine
# running this container. Use the Pi's LAN IP or hostname, NOT localhost.
DASHBOARD_URL=http://family-pi.local:3000

# Dashboard admin PIN. Only required for admin actions (e.g. create_chore).
# Read-only tools and most kiosk actions work without it.
ADMIN_PIN=1234

# Optional API key Open WebUI must present to call the tool server. Leave
# blank to allow unauthenticated access on your LAN. Generate one with:
#   openssl rand -hex 24
MCPO_API_KEY=

# Port the OpenAPI endpoint listens on (mapped to the host).
PORT=8000
