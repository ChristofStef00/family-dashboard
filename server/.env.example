# Family Dashboard — server environment.
# Copy to server/.env and fill in the values that apply to your setup.

# --- Core ---
PORT=3000
NODE_ENV=production
# Defaults are fine; uncomment to override.
# DB_PATH=./data/family.db
# UPLOAD_DIR=./uploads

# --- Admin auth ---
# 4–8 digits. The kiosk display never needs the PIN; only the admin panel does.
ADMIN_PIN=1234
# Random string for signing admin JWTs. Generate with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# --- Google Calendar (optional) ---
# Create an OAuth client in https://console.cloud.google.com/apis/credentials
# Type: "Web application". Authorized redirect URI must match GOOGLE_REDIRECT_URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Use the Pi's LAN URL or hostname here, e.g. http://family-pi.local:3000/api/calendar/oauth/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/oauth/callback

# --- Mealie integration (optional) ---
# MEALIE_URL=http://your-mealie-host:9000
# MEALIE_TOKEN=
